VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional. Canonical site origin for OAuth return when NOT on localhost
# (e.g. behind a reverse proxy). Leave unset on normal Vercel deploys —
# the app uses window.location.origin. Do NOT set this to production while
# developing locally; localhost always ignores this override.
# VITE_AUTH_REDIRECT_ORIGIN=https://your-production-domain.com
